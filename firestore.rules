rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isContractor() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/contractors/$(request.auth.uid));
    }

    function projectIsClosed(projectId) {
      return get(/databases/$(database)/documents/projects/$(projectId)).data.status == 'closed';
    }

    // Marker collection: a document here (created manually in the
    // Firebase console) is what turns a normal Firebase Auth account
    // into a contractor account. Nobody can write it from the client.
    match /contractors/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }

    // A group ties several projects (locations) together for one owner
    // to see at once. Same capability-link model as projects: anyone who
    // knows the group ID can open it, but only the contractor can browse
    // the full list or change which projects belong to it. The owner
    // view never runs an open query against /projects — it fetches each
    // project in projectIds one by one, so it can never see anything
    // outside its own group.
    match /groups/{groupId} {
      allow get: if request.auth != null;
      allow list, create, update, delete: if isContractor();
    }

    // A location is a fixed place (e.g. one restaurant) that can have many
    // rounds (projects) over time — one per job that comes up there. Same
    // capability-link model as groups: knowing the ID gets you in, but
    // only the contractor can browse all locations or manage which rounds
    // belong to one.
    match /locations/{locationId} {
      allow get: if request.auth != null;
      allow list, create, delete: if isContractor();

      // Contractor can change anything. A non-contractor (a manager
      // starting a new round from their location page) can only ever
      // touch the roundIds list — never the name, address, group, or
      // contractor fields.
      allow update: if isContractor() ||
        (request.auth != null &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['roundIds']));
    }

    // Notification emails go through the Firebase "Trigger Email"
    // extension, which watches this collection. Locked down hard: a
    // write is only accepted if the "to" address exactly matches the
    // contractorNotifyEmail already stored on the referenced project —
    // so this can never be used to email anyone except the contractor
    // who owns that specific project. Nobody (not even the contractor)
    // can read these back or edit them after creation; only the
    // extension's backend function touches them from here, and that
    // runs with admin privileges outside these rules.
    match /mail/{mailId} {
      allow create: if request.auth != null &&
        request.resource.data.projectId is string &&
        request.resource.data.keys().hasOnly(['to', 'message', 'projectId']) &&
        (
          request.resource.data.to ==
            [get(/databases/$(database)/documents/projects/$(request.resource.data.projectId)).data.contractorNotifyEmail] ||
          (isContractor() &&
            request.resource.data.to ==
              [get(/databases/$(database)/documents/projects/$(request.resource.data.projectId)).data.customerEmail])
        );
      allow read, list, update, delete: if false;
    }

    match /projects/{projectId} {
      // A project can be fetched directly if you already know its ID
      // (i.e. you have the share link) — but the collection can only
      // be *listed/browsed* by the contractor. This is what stops a
      // customer (or anyone else) from enumerating every project.
      allow get: if request.auth != null;
      allow list: if isContractor();

      // Contractor can create any project. A non-contractor can only ever
      // create a *blank* project (used by the public /start link) — name
      // and address empty, status open, and pointed at a real contractor
      // account. This is what lets a fixed link safely spin up a fresh
      // punch list for whoever opens it, without opening the door to
      // arbitrary writes.
      // Contractor can create any project. A non-contractor can create in
      // two specific, locked-down cases:
      // 1. A *blank* project (used by the public /start link) — name and
      //    address empty, status open, pointed at a real contractor.
      // 2. A new round at a location they already have the link to —
      //    must reference a real location, and its contractorUid /
      //    contractorNotifyEmail must exactly match what's already
      //    stored on that location, so nobody can point a new round (or
      //    its notification emails) at a different contractor account.
      allow create: if isContractor() ||
        (request.auth != null &&
          request.resource.data.customerName == '' &&
          request.resource.data.address == '' &&
          request.resource.data.status == 'open' &&
          exists(/databases/$(database)/documents/contractors/$(request.resource.data.contractorUid))) ||
        (request.auth != null &&
          request.resource.data.locationId is string &&
          request.resource.data.status == 'open' &&
          request.resource.data.contractorUid ==
            get(/databases/$(database)/documents/locations/$(request.resource.data.locationId)).data.contractorUid &&
          request.resource.data.contractorNotifyEmail ==
            get(/databases/$(database)/documents/locations/$(request.resource.data.locationId)).data.contractorNotifyEmail);

      allow delete: if isContractor();

      // Contractor can update anything. A non-contractor (the customer)
      // may write their own signature fields any time, and may fill in
      // their name/email/address exactly once — only while those fields
      // are still empty, so a link can't be used to overwrite someone
      // else's project info later.
      allow update: if isContractor() ||
        (request.auth != null &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['customerSignature', 'customerSignedName', 'customerSignedAt'])) ||
        (request.auth != null &&
          (resource.data.customerName == '' || resource.data.address == '') &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['customerName', 'customerEmail', 'address']));

      match /items/{itemId} {
        allow get, list: if request.auth != null;

        // Customers can only add/edit items while the project is open.
        // Contractors can always add/edit, even after closing, to fix
        // records.
        allow create: if isContractor() ||
          (request.auth != null && !projectIsClosed(projectId));

        // Contractor can change anything. A non-contractor (the
        // customer) can only ever touch their own photo list — never
        // the assessment or status fields — and only while open.
        allow update: if isContractor() ||
          (request.auth != null &&
            !projectIsClosed(projectId) &&
            request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['customerPhotos', 'history', 'comments', 'updatedAt']));

        allow delete: if isContractor();
      }
    }
  }
}
