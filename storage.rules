rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    match /projects/{projectId}/{itemId}/{kind}/{fileName} {
      allow read: if request.auth != null;

      allow create, update: if request.auth != null
        && (kind == 'customer' || kind == 'contractor')
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');

      // Only the contractor can delete photos — used when a whole
      // project is permanently deleted from the dashboard.
      allow delete: if request.auth != null &&
        firestore.exists(/databases/(default)/documents/contractors/$(request.auth.uid));
    }

    // Deleting a project first lists every file under it (at every
    // folder depth) before deleting them one by one. Without this rule,
    // that listing step is silently denied — even though the delete
    // rule above is correct — which is what was causing "Couldn't
    // delete" this whole time.
    match /projects/{projectId}/{allPaths=**} {
      allow list: if request.auth != null &&
        firestore.exists(/databases/(default)/documents/contractors/$(request.auth.uid));
    }
  }
}
